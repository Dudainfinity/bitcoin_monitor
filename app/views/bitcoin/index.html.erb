<div class="container">
  <div class="card">
    <h1>💰 Bitcoin</h1>

    <select id="moeda">
      <option value="usd">USD</option>
      <option value="brl" selected>BRL</option>
      <option value="eur">EUR</option>
    </select>

    <div class="price" id="preco">Carregando...</div>

    <canvas id="grafico"></canvas>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>


<script>
let precos = [];
let labels = [];

const ctx = document.getElementById('grafico').getContext('2d');

const grafico = new Chart(ctx, {
  type: 'line',
  data: {
    labels: labels,
    datasets: [{
      label: 'Preço BTC',
      data: precos,
      borderColor: '#3b82f6',
      backgroundColor: 'rgba(59, 130, 246, 0.1)',
      borderWidth: 2,
      pointBackgroundColor: '#3b82f6',
      tension: 0.3,
      fill: true
    }]
  },
  options: {
    responsive: true,
    plugins: {
      legend: {
        labels: { color: '#ffffff' }
      }
    },
    scales: {
      x: {
        ticks: { color: '#94a3b8' },
        grid: { color: 'rgba(255,255,255,0.05)' }
      },
      y: {
        ticks: { color: '#94a3b8' },
        grid: { color: 'rgba(255,255,255,0.05)' }
      }
    }
  }
});

async function atualizarPreco() {
  try {
    const moeda = document.getElementById("moeda").value;

    const response = await fetch(`/bitcoin/preco.json?moeda=${moeda}`);
    const data = await response.json();

    if (data.erro) throw new Error(data.erro);

    const preco = data.preco;

    const formatado = new Intl.NumberFormat('pt-BR', {
      style: 'currency',
      currency: moeda.toUpperCase(),
      minimumFractionDigits: 2
    }).format(preco);

    document.getElementById("preco").innerText = formatado;

    const agora = new Date().toLocaleTimeString();

    labels.push(agora);
    precos.push(preco);

    if (precos.length > 10) {
      precos.shift();
      labels.shift();
    }

    grafico.update();
  } catch (error) {
    document.getElementById("preco").innerText = "Erro ao buscar preço";
    console.error(error);
  }
}

atualizarPreco();
setInterval(atualizarPreco, 10000);

document.getElementById("moeda").addEventListener("change", () => {
  precos = [];
  labels = [];
  grafico.data.labels = labels;
  grafico.data.datasets[0].data = precos;
  grafico.update();
  atualizarPreco();
});
</script>
